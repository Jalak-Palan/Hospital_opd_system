# ==============================================
# HOSPITAL OPD SYSTEM - ENVIRONMENT VARIABLES
# ==============================================

# SERVER CONFIGURATION
PORT=3000
NODE_ENV=development

# DATABASE CONFIGURATION
MONGO_URI=mongodb://localhost:27017/hospital_opd
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/hospital_opd

# JWT AUTHENTICATION
JWT_Secret=your_super_secret_jwt_key_change_this_in_production

# EMAIL CONFIGURATION (Gmail)
EMAIL=your-email@gmail.com
PASSWD=your_gmail_app_password_here

# ADMIN CREDENTIALS
ADMIN_EMAIL=admin@hospital.com
ADMIN_PASSWORD=admin123

# IMAGEKIT (Optional)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# APPLICATION URL
APP_URL=http://localhost:3000
